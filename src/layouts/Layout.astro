---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<!-- <html lang="en"> -->
 <html lang="en" class="scroll-smooth scroll-pt-24 md:scroll-pt-28 lg:scroll-pt-32 xl:scroll-pt-32">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Hansi Leading Page</title>
		<meta name="description" content="A modern landing page built with Astro" />
		<link href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap" rel="stylesheet">
	</head>
	<!-- <body class="font-sans scroll-smooth"> -->
	<body class="font-sans">
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
		<script>
			import AOS from 'aos';
			import 'aos/dist/aos.css';
			AOS.init();
		</script>
		<script src="https://cdn.jsdelivr.net/npm/preline@2.0.3/dist/preline.min.js"></script>
	</body>
</html>