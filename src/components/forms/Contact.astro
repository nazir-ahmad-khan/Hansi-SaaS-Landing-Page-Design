---
// Contact section component
import contactBlurBg from "../../assets/images/Contact/contactBlurBg.png?url";
import AnimatedButton from "../ui/AnimatedButton.astro";

import Call from "../../assets/icons/contactIcon/call.png?url";
import Email from "../../assets/icons/contactIcon/mail.png?url";
import Location from "../../assets/icons/contactIcon/location.png?url";
---

<section id="contact" class="py-12 sm:py-16 md:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 lg:px-8">
    <div
      class="relative flex flex-col items-center text-center mb-12 sm:mb-28 overflow-visible"
      data-aos="fade-up"
    >
      <!-- BACKGROUND IMAGE (OUTSIDE EFFECT) -->
      <div
        class="absolute flex flex-col items-center left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] sm:w-[120%] md:w-[110%] lg:w-[100%] pointer-events-none"
      >
        <img
          src={contactBlurBg}
          alt="background"
          class="w-full h-[22rem] opacity-70"
        />
      </div>

      <!-- TEXT -->
      <h1
        class="relative z-10 font-semibold leading-tight sm:leading-[72px] tracking-[-0.03em] text-[#1C1C1C] text-2xl sm:text-3xl md:text-5xl lg:text-[56px]"
      >
        Got Questions or <br />
        <span class="text-[#664CDD]">Need Help?</span>
      </h1>

      <p
        class="relative z-10 text-sm sm:text-base md:text-md lg:text-lg leading-relaxed text-[#1C1C1C] max-w-lg"
      >
        Just shoot us an email, give us a call, or fill out our contact form.
        We're here for you!
      </p>
    </div>

    

    <div class="grid grid-cols-1 lg:grid-cols-[40%_56%] gap-6 lg:gap-10">
      <!-- ================= LEFT: QUICK CONTACT ================= -->
      <div
        data-aos="fade-up"
        class="bg-gradient-to-b from-[#f6f4fd] via-[#f9f8fd] to-[#ffffff] rounded-3xl p-6 sm:p-8 lg:p-12 flex flex-col justify-around"
      >
        <h3 class="text-2xl sm:text-3xl font-semibold text-[#1C1C1C] mb-6">
          Quick Contacts
        </h3>

        <div class="space-y-4">
          <!-- ITEM -->
          <div class="flex items-center gap-4 bg-white px-4 py-8 rounded-2xl">
            <div
              class="w-10 h-10 flex items-center justify-center bg-[#EEF2FF] rounded-full">
              <img src={Call} alt="Call" class="w-5 h-5 object-contain" />
            </div>

            <span class="text-[#1C1C1C] text-sm sm:text-[18px]">
              +001 480 555-0103
            </span>
          </div>

          <!-- ITEM -->
          <div class="flex items-center gap-4 bg-white px-4 py-8 rounded-2xl">
            <div
              class="w-10 h-10 flex items-center justify-center bg-[#EEF2FF] rounded-full">
              <img src={Email} alt="Call" class="w-5 h-5 object-contain" />
            </div>

            <span class="text-[#1C1C1C] text-sm sm:text-[18px]">
              hello@upstart.com
            </span>
          </div>

          <!-- ITEM -->
          <div class="flex items-center gap-4 bg-white px-4 py-8 rounded-2xl">
            <div
              class="w-10 h-10 flex items-center justify-center bg-[#EEF2FF] rounded-full">
              <img src={Location} alt="Call" class="w-5 h-5 object-contain" />
            </div>

            <span class="text-[#1C1C1C] text-sm sm:text-[18px] w-[80%]">
              123 Innovation Drive, Tech City, CA 94043
            </span>
          </div>

        </div>
      </div>

      <!-- ================= RIGHT: FORM ================= -->
      <div
        data-aos="fade-up"
        class="bg-[#FFFFFF] rounded-3xl p-6 sm:p-6 lg:p-12"
      >
        <form class="space-y-3">
          <!-- NAME ROW -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-sm text-gray-700 mb-1 block"
                >First Name *</label
              >
              <input
                type="text"
                class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#664CDD] outline-none"
                placeholder="Enter first name"
              />
            </div>

            <div>
              <label class="text-sm text-gray-700 mb-1 block">Last Name *</label
              >
              <input
                type="text"
                class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#664CDD] outline-none"
                placeholder="Enter last name"
              />
            </div>
          </div>

          <!-- EMAIL -->
          <div>
            <label class="text-sm text-gray-700 mb-1 block">Email *</label>
            <input
              type="email"
              class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#664CDD] outline-none"
              placeholder="Enter your email"
            />
          </div>

          <!-- SUBJECT -->
          <div>
            <label class="text-sm text-gray-700 mb-1 block">Subject *</label>
            <input
              type="text"
              class="w-full px-4 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#664CDD] outline-none"
              placeholder="Enter subject"
            />
          </div>

          <!-- MESSAGE -->
          <div>
            <label class="text-sm text-gray-700 mb-1 block">Write Message</label
            >
            <textarea
              rows="4"
              class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#664CDD] outline-none"
              placeholder="Write your message"></textarea>
          </div>

          <!-- BUTTON -->
          <!-- <button
        class="bg-[#664CDD] hover:bg-[#5a3fe0] text-white px-8 py-3 rounded-full font-semibold transition w-full sm:w-auto">
        Send Message
      </button> -->
          <AnimatedButton text="Send Message" />
        </form>
      </div>
    </div>
  </div>
</section>


<!-- ==================== Location Section===========================  -->

<section id="contact" class="py-16 sm:py-20 md:py-24 bg-gray-50">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
  
    <div
      class="relative flex flex-col items-center text-center mb-12"
      data-aos="fade-up"
    >

      <h1 class="relative z-10 font-semibold leading-tight tracking-[-0.03em] text-[#1C1C1C] text-2xl sm:text-3xl md:text-4xl lg:text-[56px]">
        Connect & Get in touch
      </h1>

      <p class="relative z-10 max-w-2xl mx-auto text-sm sm:text-base md:text-md lg:text-lg py-4 leading-relaxed text-[#1C1C1C]">
        Contact TellDesk today rely heavily on digital mean research <br/>
        products we are research a brand blends with more real engaging.
      </p>
    </div>

    <!-- Map -->
    <div class="w-full h-[300px] sm:h-[400px] md:h-[500px] lg:h-[600px] rounded-2xl overflow-hidden border border-gray-200 shadow-lg">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3943.0146131566403!2d-122.18881999939974!3d37.48584253453056!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x808fa33a07f883b1%3A0x72d789298361e2f4!2sInnovative%20Drive%20Corporation!5e0!3m2!1sen!2s!4v1776183383624!5m2!1sen!2s"
        class="w-full h-full border-0"
        loading="lazy"
        allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

  </div>
</section>