      <!-- ✅ Description -->
      <p
        class="text-xs sm:text-sm md:text-base text-[#1c1c1c] max-w-lg mx-auto px-1"
      >
        Elevate your productivity with our innovative AI-powered platform.
        Achieve unparalleled efficiency and streamline.
      </p>
    </div>
    <div>
      <!-- ✅ Toggle Button (Monthly/Yearly) -->
      <PricingToggle client:load />
    </div>

    
    
