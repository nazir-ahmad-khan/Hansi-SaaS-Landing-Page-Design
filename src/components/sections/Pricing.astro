      </div>

      <!-- ✅ Main Heading -->
      <div
        class="text-center mb-4 sm:mb-6"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <h2
          class="text-2xl sm:text-3xl md:text-4xl lg:text-[48px] font-semibold text-[#1c1c1c] mb-2 leading-tight"
