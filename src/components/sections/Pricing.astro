---
// ✅ Modern Pricing Section - Fully Responsive
// Features: Badge + Icon, Interactive Toggle, 3 Pricing Cards, Responsive Design

import FeatureBadgeIcon from "../../assets/icons/BadgeIcon/fi_feature.png?url";

import AnimatedButton from "../ui/AnimatedButton.astro";
import PricingToggle from "../forms/PricingToggle.jsx";

// Features Comparison
import Crown from "../../assets/icons/FeaturesComparison/crown.png?url";
import Vector from "../../assets/icons/FeaturesComparison/Vector.png?url";
import Vector1 from "../../assets/icons/FeaturesComparison/Vector1.png?url";
import Vector2 from "../../assets/icons/FeaturesComparison/Vector2.png?url";
