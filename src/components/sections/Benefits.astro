---
// imports same rahain
import FeatureBadgeIcon from "../../assets/icons/BadgeIcon/fi_feature.png?url";

import Savings from "../../assets/icons/Benefits/savings.png?url";
import ImprovedAccuracy from "../../assets/icons/Benefits/accuracy.png?url";
import FasterTime from "../../assets/icons/Benefits/Faster-Time.png?url";
import IncreasedProductivity from "../../assets/icons/Benefits/Increased-Productivity.png?url";

import SmallContainer from "../../assets/images/Benefits/SmallContainer.png?url";
import Container from "../../assets/images/Benefits/Container.png?url";
import MetricItem from "../../assets/images/Benefits/Metric-item.png?url";
---

<section id="benefits" class="py-8 sm:py-12 md:py-12 lg:py-12 bg-white">
  
  <div
    class="w-full max-w-screen-xl mx-auto
    h-auto bg-[#F8F6FF] py-8 sm:py-12 md:py-16 lg:py-8 xl:py-16 px-4 sm:px-8 md:px-12 lg:px-12 rounded-3xl"
  >

    <!-- Top Badge (same) -->
    <div class="flex justify-center mb-4 sm:mb-6" data-aos="fade-up">
      <span class="inline-flex items-center gap-2 rounded-full border border-[#E9D5FF] bg-white px-3 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm font-semibold text-[#7C3AED] shadow-sm">
        <img src={FeatureBadgeIcon} alt="Feature badge icon" class="w-4 h-4" />
        Benefits
      </span>
    </div>

    <!-- Heading (same) -->
    <div class="text-center mb-4 sm:mb-6" data-aos="fade-up" data-aos-delay="100">
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-[48px] font-semibold text-[#1c1c1c] mb-2 leading-tight">
        Why Businesses<br class="hidden sm:block" /> Choose Our Platform
      </h2>
    </div>

    <!-- Description (same) -->
    <div class="text-center mb-6 sm:mb-8" data-aos="fade-up" data-aos-delay="200">
      <p class="text-xs sm:text-sm md:text-base text-gray-700 max-w-md mx-auto px-2">
        Elevate your productivity with our innovative AI-powered platform.
        Achieve unparalleled efficiency and streamline.
      </p>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-1 lg:grid-cols-2
      gap-6 sm:gap-8 md:gap-10 lg:gap-6 xl:gap-10 mt-10 sm:mt-12 md:mt-16 items-start"
    >

      <!-- LEFT SIDE -->
      <div class="w-full h-auto space-y-3 sm:space-y-4">

        <!-- Box 1 (same) -->
        <div
          data-aos="fade-up"
          class="flex sm:flex-row gap-3 sm:gap-4 border border-[#664CDD] rounded-4xl p-4 sm:p-6 md:p-8
          bg-gradient-to-b from-[#DDE5FE] via-[#f4f5f8] to-[#ffffff]"
        >
          <div class="w-10 h-10 sm:w-12 md:h-20 flex-shrink-0">
            <img src={IncreasedProductivity} alt="Increased Productivity Icon" class="w-10 h-10 sm:w-12 sm:h-12" />
          </div>

          <div>
            <h3 class="font-semibold text-lg sm:text-xl text-[#1c1c1c]">
              Increased Productivity
            </h3>

            <p class="text-[#1c1c1c] text-xs sm:text-sm md:text-base mt-1">
              Automate routine tasks and focus on what matters most. Our users report completing projects 3x faster with
            </p>
          </div>
        </div>

        <!-- Box 2 -->
        <div data-aos="fade-up" data-aos-delay="100"
          class="flex items-center gap-2 sm:gap-3 rounded-3xl p-4 sm:p-6 bg-white border border-[#E8E8E8]">

          <div class="w-8 h-8 sm:w-10 md:h-12 flex items-center justify-center flex-shrink-0">
            <img src={Savings} alt="Cost Savings Icon" class="w-5 h-5 sm:w-6 sm:h-6 object-contain" />
          </div>

          <h3 class="font-semibold text-[#1c1c1c] text-lg sm:text-xl">
            Cost Savings
          </h3>
        </div>

        <!-- Box 3 -->
        <div data-aos="fade-up" data-aos-delay="200"
          class="flex items-center gap-2 sm:gap-3 rounded-3xl p-4 sm:p-6 bg-white border border-[#E8E8E8]">

          <div class="w-8 h-8 sm:w-10 md:h-12  flex items-center justify-center flex-shrink-0">
            <img src={ImprovedAccuracy} alt="Improved Accuracy Icon" class="w-5 h-5 sm:w-6 sm:h-6 object-contain" />
          </div>

          <h3 class="font-semibold text-[#1c1c1c] text-lg sm:text-xl">
            Improved Accuracy
          </h3>
        </div>

        <!-- Box 4 -->
        <div data-aos="fade-up" data-aos-delay="300"
          class="flex items-center gap-2 sm:gap-3 rounded-3xl p-4 sm:p-6 bg-white border border-[#E8E8E8]">

          <div class="w-8 h-8 sm:w-10 md:h-12 flex items-center justify-center flex-shrink-0">
            <img src={FasterTime} alt="Faster Time Icon" class="w-5 h-5 sm:w-6 sm:h-6 object-contain" />
          </div>

          <h3 class="font-semibold text-[#1c1c1c] text-lg sm:text-xl">
            Faster Time-to-Market
          </h3>
        </div>
      </div>

      <!-- RIGHT SIDE -->
      <div
        data-aos="fade-up"
        class="w-full bg-gradient-to-b from-[#E5E1FC] via-[#f6f5fa] to-[#ffffff] rounded-3xl 
        p-4 sm:p-6 md:p-10 min-h-[300px] sm:min-h-[380px] md:min-h-[439px] 
        flex flex-col items-center justify-center overflow-hidden"
      >
        <div class="flex items-end justify-center w-full gap-2">

          <img src={SmallContainer} alt="small"
            class="w-[30%] max-w-[120px] h-auto rounded-xl" />

          <img src={Container} alt="container"
            class="w-[70%] max-w-md h-auto rounded-2xl" />
        </div>

        <div class="mt-2 sm:mt-3 md:mt-4 w-full flex justify-center">
          <img src={MetricItem} alt="metric"
            class="w-full max-w-md rounded-2xl" />
        </div>
      </div>

    </div>
  </div>
</section>