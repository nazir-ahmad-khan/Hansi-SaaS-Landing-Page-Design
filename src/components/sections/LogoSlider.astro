---
import LogoBackground from "../../assets/logos/Logo/Logo-Background.png";
import Novadex from "../../assets/logos/Logo/novadex.png?url";
import Vireon from "../../assets/logos/Logo/vireon.png?url";
import Quixana from "../../assets/logos/Logo/quixana.png?url";
import Lumessa from "../../assets/logos/Logo/lumessa.png?url";
import Zenithia from "../../assets/logos/Logo/zenithia.png?url";
import Equinix from "../../assets/logos/Logo/equinix.png?url";
---

<style>
  .slider {
    overflow: hidden;
    width: 100%;
  }

  .slide-track {
    display: inline-flex;
    width: max-content;
    animation: scroll 25s linear infinite;
    align-items: center;
  }

  .slide {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 110px;
    flex-shrink: 0;
    margin: 0 18px;
  }

  .slide img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* ✅ MOBILE FIX */
  @media (max-width: 768px) {
    .slide {
      width: 80px;
      margin: 0 10px;
    }

    .slide-track {
      animation-duration: 18s;
    }
  }

  @media (max-width: 480px) {
    .slide {
      width: 70px;
      margin: 0 8px;
    }

    .slide-track {
      animation-duration: 15s;
    }
  }
</style>

<section
  class="pt-[24%] sm:pt-[16%] md:pt-[28%] lg:pt-[20%] xl:pt-[26%] pb-8 sm:pb-12 md:pb-16 bg-white px-4 sm:px-6 md:px-8 lg:px-16 xl:px-20 overflow-hidden"
  style={`background-image: url(${LogoBackground}); background-size: cover; background-position: center;`}
>

  <div class="text-center mb-8 sm:mb-10 text-[#1C1C1C]">
    <h1 class="text-sm sm:text-[16px] font-semibold">
      Trusted by 5,000+ Companies Worldwide
    </h1>
  </div>

  <div class="slider">
    <div class="slide-track">

      <!-- ORIGINAL -->
      <div class="slide"><img src={Novadex} alt="logo" /></div>
      <div class="slide"><img src={Vireon} alt="logo" /></div>
      <div class="slide"><img src={Quixana} alt="logo" /></div>
      <div class="slide"><img src={Lumessa} alt="logo" /></div>
      <div class="slide"><img src={Zenithia} alt="logo" /></div>
      <div class="slide"><img src={Equinix} alt="logo" /></div>

      <!-- DUPLICATE -->
      <div class="slide"><img src={Novadex} alt="logo" /></div>
      <div class="slide"><img src={Vireon} alt="logo" /></div>
      <div class="slide"><img src={Quixana} alt="logo" /></div>
      <div class="slide"><img src={Lumessa} alt="logo" /></div>
      <div class="slide"><img src={Zenithia} alt="logo" /></div>
      <div class="slide"><img src={Equinix} alt="logo" /></div>

    </div>
  </div>

</section>