---
import HeaderLogo from "../../assets/logos/header-logo.png?url";
---

<header class="bg-white shadow-sm sticky top-2 z-50 w-full">

  <nav class="max-w-[1440px] h-20 mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">

    <!-- ================= LEFT LOGO ================= -->
    <div class="flex-shrink-0">
      <a href="/#hero">
        <img src={HeaderLogo} alt="Logo" class="h-8 sm:h-10" />
      </a>
    </div>

    <!-- ================= CENTER MENU ================= -->
    <ul class="hidden md:flex items-center space-x-6 md:space-x-4 lg:space-x-10">

      <li>
        <a href="#features" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
          Features
        </a>
      </li>

      <li>
        <a href="#benefits" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
          Benefits
        </a>
      </li>

      <li>
        <a href="#integrations" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
          Integrations
        </a>
      </li>

      <li>
        <a href="#pricing" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
          Pricing
        </a>
      </li>

      <li>
        <a href="#blog" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
          Blog
        </a>
      </li>

      <li>
    <a href="/contact" class="text-[#1C1C1C] hover:text-[#664CDD] transition duration-300">
      Contact
    </a>
  </li>

    </ul>

    <!-- ================= RIGHT BUTTON ================= -->
    <div class="hidden md:flex">
    
    
    <!-- class="bg-[#664CDD] hover:bg-[#5a3fe0] text-white px-6 py-2 rounded-full transition duration-300" -->
        <a
        href="/contact"
        class="bg-[#664CDD] hover:bg-[#5a3fe0] text-white px-6 py-2 rounded-full whitespace-nowrap transition duration-300"
      >
        Start Free Trial
      </a>
    </div>

    <!-- ================= MOBILE BUTTON ================= -->
    <button
      id="mobile-menu-button"
      class="md:hidden text-[#1C1C1C]"
      aria-label="Toggle menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

  </nav>

  <!-- ================= MOBILE MENU ================= -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-200"
  >
    <ul class="flex flex-col text-center py-4 space-y-4">

      <li><a href="#features" class="hover:text-[#664CDD]">Features</a></li>
      <li><a href="#benefits" class="hover:text-[#664CDD]">Benefits</a></li>
      <li><a href="#integrations" class="hover:text-[#664CDD]">Integrations</a></li>
      <li><a href="#pricing" class="hover:text-[#664CDD]">Pricing</a></li>
      <li><a href="#blog" class="hover:text-[#664CDD]">Blog</a></li>
      <li><a href="/contact" class="hover:text-[#664CDD]">Contact</a></li>

      <li class="pt-2">
        <a
          href="#contact"
          class="bg-[#664CDD] text-white px-6 py-2 rounded-full inline-block"
        >
          Start Free Trial
        </a>
      </li>

    </ul>
  </div>

</header>

<!-- ================= SCRIPT ================= -->
<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  if (button && menu) {
    button.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  }

  // Smooth scroll (important UX upgrade)
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener("click", function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute("href"));
      if (target) {
        target.scrollIntoView({
          behavior: "smooth"
        });
      }
      menu.classList.add("hidden");
    });
  });

  // ✅ ALSO CLOSE MENU FOR /contact TYPE LINKS
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
    });
  });
</script>