---
import FooterLogo from "../../assets/logos/footer-logo.png?url";

import FacebookIcon from "../../assets/icons/Footer/facebook.png?url";
import InstagramIcon from "../../assets/icons/Footer/instagram.png?url";
import TwitterIcon from "../../assets/icons/Footer/twitter.png?url";
import LinkedinIcon from "../../assets/icons/Footer/linkedin.png?url";
---

<footer class="bg-[#1C1C1C] text-white pt-16 sm:pt-20 pb-10 px-4 sm:px-6">

  <div class="max-w-[1408px] mx-auto flex flex-col items-center">

    <!-- ================= TOP CTA SECTION ================= -->
    <div class="max-w-[487px] w-full flex flex-col items-center text-center mb-10 sm:mb-16">

      <h2 class="text-[26px] sm:text-[32px] md:text-[36px] leading-[34px] sm:leading-[42px] md:leading-[46px] font-semibold text-white">
        Start your 7-day free trial
      </h2>

      <p class="mt-3 text-[14px] sm:text-[15px] md:text-[16px] leading-[20px] text-white max-w-xl mx-auto px-2">
        Kick off your free trial today and enjoy smooth project management, no strings attached!
      </p>

      <!-- Input + Button -->
<div class="w-full max-w-[420px] mt-6 sm:mt-8">

  <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-0 p-2 border border-gray-700 rounded-2xl sm:rounded-full">

    <!-- Input -->
    <input
      type="email"
      placeholder="Enter your email"
      class="w-full bg-transparent px-5 py-2 text-[14px] sm:text-[16px] text-white placeholder-white/60 outline-none"
    />

    <!-- Button -->
    <button class="bg-[#6C4DFF] hover:bg-[#5a3fe0] sm:ml-2 whitespace-nowrap rounded-full px-5 py-2 text-[14px] sm:text-[16px] font-medium transition">
      Get Started
    </button>

  </div>

</div>

    </div>

    <!-- ================= BOTTOM FOOTER GRID ================= -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 sm:gap-10 w-full">

      <!-- ===== Logo + Contact ===== -->
      <div>
        <img src={FooterLogo} alt="Hansi Logo" class="mb-6 sm:mb-8 w-28 sm:w-32" />

        <ul class="space-y-3 text-[14px] sm:text-[15px] md:text-[16px] text-white/80">

          <li>
            <a href="tel:+15551234567" class="hover:text-[#664CDD] transition duration-300">
              (555) 123-4567
            </a>
          </li>

          <li>
            <a href="mailto:hello@hansi.com" class="hover:text-[#664CDD] transition duration-300">
              hello@hansi.com
            </a>
          </li>

          <li>123 Innovation Drive, Tech City, CA 94043</li>

        </ul>

        <!-- Social Icons -->
        <div class="flex gap-4 mt-5">

          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer">
            <img src={FacebookIcon} class="w-4 h-4 sm:w-5 sm:h-5 opacity-70 hover:opacity-100 hover:scale-110 transition duration-300" />
          </a>

          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">
            <img src={LinkedinIcon} class="w-4 h-4 sm:w-5 sm:h-5 opacity-70 hover:opacity-100 hover:scale-110 transition duration-300" />
          </a>

          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">
            <img src={TwitterIcon} class="w-4 h-4 sm:w-5 sm:h-5 opacity-70 hover:opacity-100 hover:scale-110 transition duration-300" />
          </a>

          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">
            <img src={InstagramIcon} class="w-4 h-4 sm:w-5 sm:h-5 opacity-70 hover:opacity-100 hover:scale-110 transition duration-300" />
          </a>

        </div>
      </div>

      <!-- ===== Product ===== -->
      <div>
        <h3 class="text-[18px] sm:text-[20px] font-medium mb-4">Product</h3>

        <ul class="space-y-3 text-[14px] sm:text-[15px] md:text-[16px] text-white/80">

          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Features</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Integrations</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Pricing</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Security</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">API Documentation</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Changelog</a></li>

        </ul>
      </div>

      <!-- ===== Resources ===== -->
      <div>
        <h3 class="text-[18px] sm:text-[20px] font-medium mb-4">Resources</h3>

        <ul class="space-y-3 text-[14px] sm:text-[15px] md:text-[16px] text-white/80">

          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Help Center</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Blog</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Case Studies</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Webinars</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Templates</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Community</a></li>

        </ul>
      </div>

      <!-- ===== Company ===== -->
      <div>
        <h3 class="text-[18px] sm:text-[20px] font-medium mb-4">Company</h3>

        <ul class="space-y-3 text-[14px] sm:text-[15px] md:text-[16px] text-white/80">

          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">About Us</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Careers</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Press Kit</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Partners</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Contact</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Status Page</a></li>

        </ul>
      </div>

      <!-- ===== Legal ===== -->
      <div>
        <h3 class="text-[18px] sm:text-[20px] font-medium mb-4">Legal</h3>

        <ul class="space-y-3 text-[14px] sm:text-[15px] md:text-[16px] text-white/80">

          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Terms of Service</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Cookie Policy</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Data Processing Agreement</a></li>
          <li><a href="#" class="hover:text-[#664CDD] transition duration-300">Compliance</a></li>

        </ul>
      </div>

    </div>

    <!-- ================= COPYRIGHT ================= -->
    <div class="w-full border-t border-white/10 mt-10 sm:mt-12 pt-4 sm:pt-6 text-center text-white/60 text-xs sm:text-sm">
      Copyright © 2025 Hansi All Rights Reserved
    </div>

  </div>
</footer>